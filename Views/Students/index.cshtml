@model IEnumerable<StudentPortal.Models.Student>

@{
    ViewData["Title"] = "Students";
}

@section Styles {
<style>
    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 16px;
        flex-wrap: wrap;
    }
    .page-header h1 {
        font-family: var(--font-head);
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }
    .page-header h1 span { color: var(--accent); }
    .page-header p { color: var(--muted); font-size: .875rem; margin-top: 4px; }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color: #fff;
        border: none;
        border-radius: 10px;
        font-family: var(--font-body);
        font-size: .875rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        box-shadow: 0 4px 16px var(--accent-glow);
        white-space: nowrap;
    }
    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 22px var(--accent-glow);
        color: #fff;
    }

    /* ── STATS ROW ── */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 22px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: border-color .2s;
    }
    .stat-card:hover { border-color: var(--accent); }
    .stat-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: grid; place-items: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }
    .stat-icon.blue  { background: rgba(91,124,250,.15); color: var(--accent); }
    .stat-icon.green { background: rgba(52,211,153,.15); color: var(--green); }
    .stat-icon.amber { background: rgba(251,191,36,.15);  color: var(--amber); }
    .stat-val {
        font-family: var(--font-head);
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }
    .stat-lbl { color: var(--muted); font-size: .8rem; margin-top: 3px; }

    /* ── TOOLBAR ── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 340px;
    }
    .search-wrap i {
        position: absolute;
        left: 14px; top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: .85rem;
    }
    .search-input {
        width: 100%;
        padding: 9px 14px 9px 38px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-family: var(--font-body);
        font-size: .875rem;
        outline: none;
        transition: border-color .2s;
    }
    .search-input::placeholder { color: var(--muted); }
    .search-input:focus { border-color: var(--accent); }
    .count-badge {
        font-size: .8rem;
        color: var(--muted);
        margin-left: auto;
    }
    .count-badge span { color: var(--text); font-weight: 600; }

    /* ── TABLE ── */
    .table-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    .data-table thead tr {
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
    }
    .data-table th {
        padding: 13px 16px;
        font-size: .75rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        white-space: nowrap;
    }
    .data-table th.center { text-align: center; }
    .data-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .15s;
    }
    .data-table tbody tr:last-child { border-bottom: none; }
    .data-table tbody tr:hover { background: rgba(91,124,250,.05); }
    .data-table td {
        padding: 14px 16px;
        font-size: .875rem;
        vertical-align: middle;
    }
    .data-table td.center { text-align: center; }

    /* serial number column */
    .serial-no {
        font-family: var(--font-head);
        font-size: .8rem;
        font-weight: 700;
        color: var(--muted);
        background: var(--surface2);
        border-radius: 6px;
        padding: 3px 9px;
        display: inline-block;
    }

    /* avatar cell */
    .student-cell { display: flex; align-items: center; gap: 12px; }
    .student-avatar {
        width: 36px; height: 36px;
        border-radius: 9px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        display: grid; place-items: center;
        font-family: var(--font-head);
        font-size: .8rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }
    .student-name { font-weight: 500; }
    .student-email { font-size: .78rem; color: var(--muted); }

    /* action buttons */
    .actions { display: flex; align-items: center; gap: 6px; justify-content: center; }
    .action-btn {
        width: 32px; height: 32px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: transparent;
        cursor: pointer;
        display: grid; place-items: center;
        font-size: .8rem;
        text-decoration: none;
        color: var(--muted);
        transition: all .2s;
    }
    .action-btn:hover        { border-color: var(--accent); color: var(--accent); background: rgba(91,124,250,.08); }
    .action-btn.delete:hover { border-color: var(--red);    color: var(--red);    background: rgba(248,113,113,.08); }
    .action-btn.view:hover   { border-color: var(--green);  color: var(--green);  background: rgba(52,211,153,.08); }

    /* empty state */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    .empty-icon {
        font-size: 3rem;
        color: var(--muted);
        opacity: .4;
        margin-bottom: 16px;
    }
    .empty-state h3 {
        font-family: var(--font-head);
        font-size: 1.1rem;
        margin-bottom: 6px;
    }
    .empty-state p { color: var(--muted); font-size: .875rem; }

    @@media(max-width: 640px) {
        .stats-row { grid-template-columns: 1fr 1fr; }
        .stats-row .stat-card:last-child { grid-column: span 2; }
        .data-table .hide-mobile { display: none; }
    }
</style>
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <h1>All <span>Students</span></h1>
        <p>Manage and view all enrolled students</p>
    </div>
    <a asp-action="Create" class="btn-primary">
        <i class="fas fa-plus"></i> Add Student
    </a>
</div>

<!-- STATS -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-users"></i></div>
        <div>
            <div class="stat-val">@Model.Count()</div>
            <div class="stat-lbl">Total Students</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-user-check"></i></div>
        <div>
            <div class="stat-val">@Model.Count()</div>
            <div class="stat-lbl">Active</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-calendar-day"></i></div>
        <div>
            <div class="stat-val">@DateTime.Now.ToString("MMM dd")</div>
            <div class="stat-lbl">Today</div>
        </div>
    </div>
</div>

<!-- TOOLBAR -->
<div class="toolbar">
    <div class="search-wrap">
        <i class="fas fa-search"></i>
        <input class="search-input" type="text" id="searchInput" placeholder="Search students…" />
    </div>
    <div class="count-badge">Showing <span id="visibleCount">@Model.Count()</span> of <span>@Model.Count()</span></div>
</div>

<!-- TABLE -->
<div class="table-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-user-graduate"></i></div>
            <h3>No students yet</h3>
            <p>Get started by adding your first student.</p>
        </div>
    }
    else
    {
        <table class="data-table" id="studentTable">
            <thead>
                <tr>
                    <th style="width:60px">#</th>
                    <th>Student</th>
                    <th class="hide-mobile">Phone</th>
                    <th class="hide-mobile">Address</th>
                    <th class="center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int rowIndex = 1; }
                @foreach (var student in Model)
                {
                    var initials = string.Concat(
                        student.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                               .Take(2)
                               .Select(w => w[0].ToString().ToUpper())
                    );
                    <tr>
                        <td><span class="serial-no">@rowIndex</span></td>
                        <td>
                            <div class="student-cell">
                                <div class="student-avatar">@initials</div>
                                <div>
                                    <div class="student-name">@student.Name</div>
                                    <div class="student-email">@student.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="hide-mobile">@student.PhoneNumber</td>
                        <td class="hide-mobile" style="max-width:180px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@student.Address</td>
                        <td class="center">
                            <div class="actions">
                                <a asp-action="Details" asp-route-id="@student.Id" class="action-btn view" title="View"><i class="fas fa-eye"></i></a>
                                <a asp-action="Edit"    asp-route-id="@student.Id" class="action-btn"      title="Edit"><i class="fas fa-pen"></i></a>
                                <a asp-action="Delete"  asp-route-id="@student.Id" class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                    rowIndex++;
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
<script>
    // Live search with row re-numbering
    const searchInput   = document.getElementById('searchInput');
    const visibleCount  = document.getElementById('visibleCount');
    const table         = document.getElementById('studentTable');

    if (searchInput && table) {
        searchInput.addEventListener('input', () => {
            const q    = searchInput.value.toLowerCase().trim();
            const rows = table.querySelectorAll('tbody tr');
            let   num  = 1, shown = 0;

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                const match = text.includes(q);
                row.style.display = match ? '' : 'none';

                if (match) {
                    // always re-number what's visible
                    const badge = row.querySelector('.serial-no');
                    if (badge) badge.textContent = num++;
                    shown++;
                }
            });

            if (visibleCount) visibleCount.textContent = shown;
        });
    }
</script>
}
