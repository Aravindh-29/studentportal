@model IEnumerable<StudentPortal.Models.Student>

@{
    ViewData["Title"] = "Dashboard";
    var avgAge = Model.Any() ? (int)Math.Round(Model.Average(s => s.Age)) : 0;
}

@section Styles {
<style>
    /* ── DASHBOARD GRID & CONTAINER ── */
    .dashboard-container {
        display: flex;
        flex-direction: column;
        gap: 28px;
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── WELCOME BANNER ── */
    .welcome-banner {
        background: linear-gradient(135deg, rgba(91, 124, 250, 0.15), rgba(167, 139, 250, 0.08));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 32px;
        position: relative;
        overflow: hidden;
    }
    .welcome-banner::before {
        content: "";
        position: absolute;
        top: -50%; right: -20%;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(91, 124, 250, 0.2) 0%, rgba(0,0,0,0) 70%);
        filter: blur(40px);
        pointer-events: none;
    }
    .welcome-banner h1 {
        font-family: var(--font-head);
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 8px;
        background: linear-gradient(90deg, #fff, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .welcome-banner p {
        color: var(--muted);
        font-size: 0.95rem;
        max-width: 600px;
        line-height: 1.5;
    }

    /* ── STATS ROW ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        border-color: rgba(91, 124, 250, 0.3);
        box-shadow: 0 8px 30px rgba(12, 15, 26, 0.4);
    }
    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 12px;
        display: grid; place-items: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .stat-icon.purple { background: rgba(167, 139, 250, 0.12); color: var(--accent2); box-shadow: 0 0 15px rgba(167, 139, 250, 0.1); }
    .stat-icon.green  { background: rgba(52, 211, 153, 0.12); color: var(--green); box-shadow: 0 0 15px rgba(52, 211, 153, 0.1); }
    .stat-icon.blue   { background: rgba(91, 124, 250, 0.12); color: var(--accent); box-shadow: 0 0 15px rgba(91, 124, 250, 0.1); }
    
    .stat-details { display: flex; flex-direction: column; }
    .stat-value {
        font-family: var(--font-head);
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1.1;
        color: var(--text);
    }
    .stat-label {
        color: var(--muted);
        font-size: 0.8rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 4px;
    }

    /* ── MAIN CONTENT SPLIT ── */
    .dashboard-split {
        display: grid;
        grid-template-columns: 1.1fr 1.9fr;
        gap: 28px;
    }

    .panel-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .panel-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .panel-header h2 {
        font-family: var(--font-head);
        font-size: 1.05rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .panel-header h2 i { color: var(--accent); }
    
    .panel-body { padding: 24px; }

    /* ── QUICK ADD FORM ── */
    .quick-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .form-group.row-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }
    .form-group label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
    }
    .form-control {
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-family: var(--font-body);
        font-size: 0.85rem;
        outline: none;
        transition: all 0.2s;
        width: 100%;
    }
    .form-control::placeholder { color: rgba(255,255,255,0.2); }
    .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(91, 124, 250, 0.15);
    }
    textarea.form-control { resize: none; min-height: 60px; }

    .btn-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 11px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color: #fff;
        border: none;
        border-radius: 10px;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 16px var(--accent-glow);
    }
    .btn-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px var(--accent-glow);
    }

    /* ── RECENT FEED LIST ── */
    .recent-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 520px;
        overflow-y: auto;
        padding-right: 4px;
    }
    /* Custom Scrollbar for Recent Feed */
    .recent-list::-webkit-scrollbar { width: 5px; }
    .recent-list::-webkit-scrollbar-track { background: transparent; }
    .recent-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

    .student-item {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        transition: all 0.2s;
    }
    .student-item:hover {
        border-color: rgba(91, 124, 250, 0.2);
        background: rgba(91, 124, 250, 0.03);
    }
    
    .student-profile {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }
    .avatar-circle {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        display: grid; place-items: center;
        color: #fff;
        font-family: var(--font-head);
        font-weight: 700;
        font-size: 0.8rem;
        flex-shrink: 0;
    }
    .student-meta { min-width: 0; }
    .student-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .student-subtitle {
        font-size: 0.75rem;
        color: var(--muted);
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .student-age-badge {
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border);
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 0.72rem;
        color: var(--muted);
        font-weight: 600;
    }

    .student-actions {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .action-icon {
        width: 30px; height: 30px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--muted);
        display: grid; place-items: center;
        text-decoration: none;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .action-icon:hover { border-color: var(--accent); color: var(--accent); background: rgba(91,124,250,.08); }
    .action-icon.danger:hover { border-color: var(--red); color: var(--red); background: rgba(248,113,113,.08); }

    /* ── EMPTY STATE ── */
    .empty-state {
        text-align: center;
        padding: 48px 16px;
    }
    .empty-icon {
        font-size: 2.5rem;
        color: var(--muted);
        opacity: 0.3;
        margin-bottom: 12px;
    }
    .empty-state h3 { font-family: var(--font-head); font-size: 1rem; margin-bottom: 4px; }
    .empty-state p { color: var(--muted); font-size: 0.8rem; }

    /* ── RESPONSIVE DESIGN ── */
    @@media (max-width: 900px) {
        .dashboard-split { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) {
        .stats-grid { grid-template-columns: 1fr; }
    }
</style>
}

<div class="dashboard-container">
    
    <!-- WELCOME BANNER -->
    <div class="welcome-banner">
        <h1>Welcome Back, Administrator</h1>
        <p>Student Portal is running efficiently with local MySQL integration. Here is a high-level overview of the current academic enrollment state.</p>
    </div>

    <!-- STATS ROW -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fas fa-users"></i></div>
            <div class="stat-details">
                <div class="stat-value">@Model.Count()</div>
                <div class="stat-label">Total Enrolled</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-hourglass-half"></i></div>
            <div class="stat-details">
                <div class="stat-value">@avgAge</div>
                <div class="stat-label">Average Age</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-database"></i></div>
            <div class="stat-details">
                <div class="stat-value" style="font-size:1.15rem; font-weight:700; color:var(--green)">
                    <span class="status-dot" style="display:inline-block; margin-right:6px"></span>ONLINE
                </div>
                <div class="stat-label">Local MySQL Db</div>
            </div>
        </div>
    </div>

    <!-- MAIN DASHBOARD CONTENT SPLIT -->
    <div class="dashboard-split">
        
        <!-- LEFT: QUICK REGISTRATION FORM -->
        <div class="panel-card">
            <div class="panel-header">
                <h2><i class="fas fa-user-plus"></i> Quick Enrolment</h2>
            </div>
            <div class="panel-body">
                <form class="quick-form" asp-action="CreateStudent" method="post">
                    
                    <div class="form-group">
                        <label>Full Name</label>
                        <input name="Name" class="form-control" placeholder="e.g. Aravindh Kumar" required />
                    </div>

                    <div class="form-group row-split">
                        <div>
                            <label>Age</label>
                            <input name="Age" type="number" class="form-control" placeholder="e.g. 21" min="1" max="120" required />
                        </div>
                        <div>
                            <label>Phone Number</label>
                            <input name="PhoneNumber" class="form-control" placeholder="e.g. +601234567" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <input name="Email" type="email" class="form-control" placeholder="student@example.com" required />
                    </div>

                    <div class="form-group">
                        <label>Street Address</label>
                        <textarea name="Address" class="form-control" placeholder="Street, City, Country..." required></textarea>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="fas fa-plus"></i> Enroll Student
                    </button>

                </form>
            </div>
        </div>

        <!-- RIGHT: RECENT ENROLMENTS -->
        <div class="panel-card">
            <div class="panel-header">
                <h2><i class="fas fa-history"></i> Latest Enrolled Students</h2>
                <div style="font-size: 0.75rem; color: var(--muted)">Showing last @Model.Count() records</div>
            </div>
            <div class="panel-body">
                
                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-graduation-cap"></i></div>
                        <h3>No students enrolled yet</h3>
                        <p>Fill out the Quick Enrolment form to add a student record.</p>
                    </div>
                }
                else
                {
                    <div class="recent-list">
                        @foreach (var student in Model.Reverse().Take(10))
                        {
                            var initials = string.Concat(
                                student.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                       .Take(2)
                                       .Select(w => w[0].ToString().ToUpper())
                            );

                            <div class="student-item">
                                <div class="student-profile">
                                    <div class="avatar-circle">@initials</div>
                                    <div class="student-meta">
                                        <div class="student-name">@student.Name</div>
                                        <div class="student-subtitle">@student.Email &nbsp;·&nbsp; @student.PhoneNumber</div>
                                    </div>
                                </div>
                                
                                <div style="display: flex; align-items: center; gap: 12px">
                                    <span class="student-age-badge">@student.Age Yrs</span>
                                    <div class="student-actions">
                                        <a href="/Students/Edit/@student.Id" class="action-icon" title="Edit Record">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a href="/Students/Delete/@student.Id" class="action-icon danger" title="Delete Record">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>

    </div>

</div>
