<div class="container mt-5">

    <div class="alert alert-danger shadow">

        <h2>Database Connection Failed</h2>

        <hr />

        <p>
            Student Portal is currently unable to connect
            to the database.
        </p>

        <p>
            Please verify:
        </p>

        <ul>
            <li>MySQL Server is running</li>
            <li>Connection String is correct</li>
            <li>Network connectivity exists</li>
        </ul>

        @if (ViewBag.DatabaseError != null)
        {
            <div class="mt-4 p-3 bg-dark text-warning rounded border border-warning" style="font-family: monospace; font-size: 0.85rem; overflow-x: auto;">
                <strong>System Error Message:</strong><br />
                @ViewBag.DatabaseError
            </div>
        }

    </div>

</div>